<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>startups.coffee — Próximamente</title>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500&display=swap");
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: "Inter", sans-serif;
      background: #0f0800;
      color: #f5e6d3;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
    }
    .bg {
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse at 50% 60%, #2a1200 0%, #0f0800 70%);
    }
    .steam {
      display: flex;
      justify-content: center;
      gap: 8px;
      height: 40px;
      margin-bottom: 4px;
    }
    .steam span {
      display: block;
      width: 4px;
      border-radius: 4px;
      background: linear-gradient(to top, #c8956c44, #c8956c00);
      animation: steam 2s ease-in-out infinite;
    }
    .steam span:nth-child(1) { animation-delay: 0s; height: 30px; }
    .steam span:nth-child(2) { animation-delay: 0.4s; height: 40px; }
    .steam span:nth-child(3) { animation-delay: 0.8s; height: 25px; }
    @keyframes steam {
      0%, 100% { transform: translateY(0) scaleX(1); opacity: 0.6; }
      50% { transform: translateY(-10px) scaleX(1.3); opacity: 0.2; }
    }
    .container {
      position: relative;
      z-index: 1;
      padding: 2rem;
    }
    svg.cup {
      width: 140px;
      height: 140px;
      filter: drop-shadow(0 8px 32px #c8956c33);
    }
    h1 {
      font-family: "Playfair Display", serif;
      font-size: 2.8rem;
      font-weight: 700;
      margin: 1.2rem 0 0.4rem;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #f5e6d3, #c8956c);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .dot { color: #c8956c; -webkit-text-fill-color: #c8956c; }
    p.tagline {
      font-size: 1rem;
      color: #a07850;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-top: 0.5rem;
    }
    .divider {
      width: 48px;
      height: 2px;
      background: linear-gradient(to right, transparent, #c8956c, transparent);
      margin: 1.8rem auto;
    }
    p.sub {
      font-size: 0.95rem;
      color: #7a5c3e;
      max-width: 320px;
      line-height: 1.7;
    }

    /* ── Chat Widget ── */
    #chat-btn {
      position: fixed;
      bottom: 24px;
      right: 24px;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: linear-gradient(135deg, #c8956c, #a06840);
      border: none;
      cursor: pointer;
      box-shadow: 0 4px 20px #c8956c44;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    #chat-btn:hover { transform: scale(1.08); box-shadow: 0 6px 28px #c8956c66; }
    #chat-btn svg { width: 26px; height: 26px; fill: #fff; }

    #chat-window {
      position: fixed;
      bottom: 90px;
      right: 24px;
      width: 30vw;
      min-width: 320px;
      max-width: 420px;
      height: calc(100vh - 120px);
      max-height: calc(100vh - 120px);
      background: #1a0d00;
      border: 1px solid #3a2010;
      border-radius: 16px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.6);
      display: flex;
      flex-direction: column;
      z-index: 999;
      overflow: hidden;
      transform: scale(0.95) translateY(8px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }
    #chat-window.open {
      transform: scale(1) translateY(0);
      opacity: 1;
      pointer-events: all;
    }

    #chat-header {
      background: linear-gradient(135deg, #2a1400, #1a0d00);
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid #3a2010;
      flex-shrink: 0;
    }
    #chat-header .avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: linear-gradient(135deg, #c8956c, #a06840);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    #chat-header .info { flex: 1; text-align: left; }
    #chat-header .name { font-size: 0.9rem; font-weight: 600; color: #f5e6d3; }
    #chat-header .status { font-size: 0.75rem; color: #8a6545; }
    #chat-close {
      background: none;
      border: none;
      cursor: pointer;
      color: #7a5c3e;
      font-size: 20px;
      line-height: 1;
      padding: 2px;
    }
    #chat-close:hover { color: #c8956c; }

    #chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
      scrollbar-width: thin;
      scrollbar-color: #3a2010 transparent;
    }
    #chat-messages::-webkit-scrollbar { width: 4px; }
    #chat-messages::-webkit-scrollbar-thumb { background: #3a2010; border-radius: 4px; }

    .msg {
      max-width: 85%;
      padding: 10px 14px;
      border-radius: 12px;
      font-size: 0.875rem;
      line-height: 1.5;
      word-break: break-word;
      text-align: left;
    }
    .msg.bot {
      background: #2a1400;
      color: #f0dcc8;
      border-bottom-left-radius: 4px;
      align-self: flex-start;
      border: 1px solid #3a2010;
    }
    .msg.user {
      background: linear-gradient(135deg, #c8956c, #a06840);
      color: #fff;
      border-bottom-right-radius: 4px;
      align-self: flex-end;
      text-align: right;
    }
    .msg.bot p { margin: 0 0 6px; }
    .msg.bot p:last-child { margin-bottom: 0; }
    .msg.bot strong { color: #f5e6d3; }
    .msg.bot ul, .msg.bot ol { padding-left: 18px; margin: 4px 0; }
    .msg.bot li { margin: 2px 0; }
    .msg.bot code { background: #1a0a00; padding: 1px 5px; border-radius: 4px; font-size: 0.82rem; color: #c8956c; }
    .msg.bot pre { background: #1a0a00; padding: 10px; border-radius: 8px; overflow-x: auto; margin: 6px 0; }
    .msg.bot pre code { background: none; padding: 0; color: #f0dcc8; }
    .msg.bot h1, .msg.bot h2, .msg.bot h3 { color: #f5e6d3; margin: 8px 0 4px; font-size: 0.95rem; }
    .msg.typing {
      background: #2a1400;
      border: 1px solid #3a2010;
      align-self: flex-start;
      color: #7a5c3e;
      font-style: italic;
    }

    #chat-input-area {
      padding: 12px;
      border-top: 1px solid #3a2010;
      display: flex;
      gap: 8px;
      flex-shrink: 0;
      background: #150a00;
    }
    #chat-input {
      flex: 1;
      background: #2a1400;
      border: 1px solid #3a2010;
      border-radius: 10px;
      padding: 10px 14px;
      color: #f5e6d3;
      font-size: 0.875rem;
      font-family: "Inter", sans-serif;
      outline: none;
      resize: none;
      height: 42px;
      max-height: 100px;
      overflow-y: auto;
    }
    #chat-input::placeholder { color: #5a3e28; }
    #chat-input:focus { border-color: #c8956c55; }
    #chat-send {
      width: 42px;
      height: 42px;
      border-radius: 10px;
      background: linear-gradient(135deg, #c8956c, #a06840);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: opacity 0.2s;
    }
    #chat-send:disabled { opacity: 0.4; cursor: default; }
    #chat-send svg { width: 18px; height: 18px; fill: #fff; }

    @media (max-width: 600px) {
      #chat-window { width: calc(100vw - 32px); min-width: unset; right: 16px; }
    }
  </style>
</head>
<body>
  <div class="bg"></div>
  <div class="container">
    <div class="steam">
      <span></span><span></span><span></span>
    </div>
    <svg class="cup" viewBox="0 0 140 140" fill="none" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="70" cy="118" rx="38" ry="6" fill="#1a0a00" opacity="0.5"/>
      <path d="M32 52 L38 112 Q38 118 44 118 L96 118 Q102 118 102 112 L108 52 Z" fill="#2a1400" stroke="#c8956c" stroke-width="1.5"/>
      <path d="M35 60 L105 60" stroke="#c8956c" stroke-width="0.5" opacity="0.3"/>
      <path d="M108 62 Q128 62 128 80 Q128 98 108 98" stroke="#c8956c" stroke-width="2" fill="none" stroke-linecap="round"/>
      <path d="M108 72 Q120 72 120 80 Q120 88 108 88" fill="#2a1400" stroke="#c8956c" stroke-width="1" opacity="0.6"/>
      <ellipse cx="70" cy="52" rx="38" ry="8" fill="#3d1f00" stroke="#c8956c" stroke-width="1.5"/>
      <ellipse cx="70" cy="52" rx="30" ry="5" fill="#5c3010" opacity="0.8"/>
      <ellipse cx="65" cy="50" rx="8" ry="3" fill="#7a4520" opacity="0.5" transform="rotate(-15 65 50)"/>
    </svg>
    <h1>startups<span class="dot">.</span>coffee</h1>
    <p class="tagline">Próximamente</p>
    <div class="divider"></div>
    <p class="sub">Algo grande se está preparando.<br>Vuelve pronto.</p>
  </div>

  <!-- Chat Button -->
  <button id="chat-btn" title="Abrir asistente">
    <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>
  </button>

  <!-- Chat Window -->
  <div id="chat-window">
    <div id="chat-header">
      <div class="avatar">☕</div>
      <div class="info">
        <div class="name">Asistente startups.coffee</div>
        <div class="status">En línea</div>
      </div>
      <button id="chat-close">✕</button>
    </div>
    <div id="chat-messages">
      <div class="msg bot">¡Hola! Soy el asistente de <strong>startups.coffee</strong> ☕<br>Puedo ayudarte con herramientas, recursos y descuentos para tu startup. ¿En qué te puedo ayudar?</div>
    </div>
    <div id="chat-input-area">
      <textarea id="chat-input" placeholder="Escribe tu mensaje..." rows="1"></textarea>
      <button id="chat-send">
        <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
      </button>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script>
    const btn = document.getElementById('chat-btn');
    const win = document.getElementById('chat-window');
    const closeBtn = document.getElementById('chat-close');
    const input = document.getElementById('chat-input');
    const send = document.getElementById('chat-send');
    const messages = document.getElementById('chat-messages');

    const history = [];
    const sessionId = crypto.randomUUID();

    const welcomeMsg = '¡Hola! Soy el asistente de <strong>startups.coffee</strong> ☕<br>Puedo ayudarte con herramientas, recursos y descuentos para tu startup. ¿En qué te puedo ayudar?';

    function resetChat() {
      history.length = 0;
      messages.innerHTML = `<div class="msg bot">${welcomeMsg}</div>`;
    }

    btn.addEventListener('click', () => {
      const opening = !win.classList.contains('open');
      win.classList.toggle('open');
      if (opening) {
        resetChat();
        input.focus();
      }
    });
    closeBtn.addEventListener('click', () => win.classList.remove('open'));

    input.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });
    send.addEventListener('click', sendMessage);

    function addMsg(text, role) {
      const div = document.createElement('div');
      div.className = `msg ${role}`;
      div.textContent = text;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
      return div;
    }

    async function sendMessage() {
      const text = input.value.trim();
      if (!text) return;

      input.value = '';
      send.disabled = true;
      addMsg(text, 'user');
      history.push({ role: 'user', content: text });

      const botDiv = addMsg('', 'bot');
      let fullReply = '';

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history, sessionId })
        });

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop();
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            const data = line.slice(6).trim();
            if (data === '[DONE]') break;
            try {
              const parsed = JSON.parse(data);
              if (parsed.token) {
                fullReply += parsed.token;
                botDiv.innerHTML = marked.parse(fullReply);
                messages.scrollTop = messages.scrollHeight;
              }
            } catch (_) {}
          }
        }

        if (!fullReply) botDiv.innerHTML = 'Lo siento, hubo un error.';
        history.push({ role: 'assistant', content: fullReply });
      } catch {
        botDiv.textContent = 'Error de conexión. Intenta de nuevo.';
      }

      send.disabled = false;
      input.focus();
    }
  </script>
</body>
</html>
